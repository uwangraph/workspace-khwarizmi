<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginBottom="160dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/label_incoming"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panggilan Masuk"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/caller_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Seseorang"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/call_type_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Panggilan Video"
            android:textColor="#64748B"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="72dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="72dp">

            <ImageButton
                android:id="@+id/btn_decline"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/circle_red"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Tolak" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Tolak"
                android:textColor="#CBD5E1"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_answer"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/circle_green"
                android:src="@android:drawable/sym_action_call"
                android:contentDescription="Angkat" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Angkat"
                android:textColor="#CBD5E1"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
